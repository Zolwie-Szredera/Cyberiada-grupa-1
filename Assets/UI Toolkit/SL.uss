:root {
}

.gambling {
    color: white;
    -unity-text-outline-width: 1px;
    -unity-text-outline-color: black;
    flex-direction: row;
    align-self: center;
    scale: 2%;
    -unity-font-style: bold;
    font-size: 20;
    background-color: black;
    border-radius: 8px;
}

.main-box {
    flex-direction: row;
}

.box {
    flex-grow: initial;
}

.lp {
    align-self: center;
}

.slot-item {
    opacity: 0.70;
}

.slot-item2 {
    opacity: 0.35;
}


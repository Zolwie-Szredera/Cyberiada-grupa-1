/*.slot-item--active {*/
/*    opacity: 1;*/
/*    background-color: rgba(255, 255, 255, 0.12);*/
/*}*/

.slot-item--far {
    opacity: 0.22;
}

.slot-r {
    background-color: gray;
    margin-left: -1px;
}

.slot-l {
    background-color: gray;
    margin-right: -1px;
}
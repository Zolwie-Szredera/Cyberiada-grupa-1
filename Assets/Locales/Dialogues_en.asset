  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogues_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: f0996fd03d3820b41b70c5cae92a57ef, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 9391366144
    m_Localized: Lily, heavy with sorrow, awaits the plucking,
    m_Metadata:
      m_Items: []
  - m_Id: 64684875776
    m_Localized: "Lay it upon your beloved\u2019s grave\u2026\n"
    m_Metadata:
      m_Items: []
  - m_Id: 2430775648256
    m_Localized: "Even though you don't remember \nanyone ever loving you, these
      fragments of \nmemory fill you with the urge to run away.\n"
    m_Metadata:
      m_Items: []
  - m_Id: 692238749589504
    m_Localized: 'Run then! You found a Lily of Shadows,

      dash strength increased.'
    m_Metadata:
      m_Items: []
  - m_Id: 7180529523023872
    m_Localized: "Such beauty... \nWhat wonders must lie in the chambers of \nthis
      palace?"
    m_Metadata:
      m_Items: []
  - m_Id: 7988329568329728
    m_Localized: 'And what pain will you have to survive to see it?

      Enemies
      approach...'
    m_Metadata:
      m_Items: []
  - m_Id: 7989706600275968
    m_Localized: "The plaque says: \n\"The greatest is the only one\"."
    m_Metadata:
      m_Items: []
  - m_Id: 7990605292822528
    m_Localized: 'A ragged patch of dry skin displayed as a

      trophy.'
    m_Metadata:
      m_Items: []
  - m_Id: 7991275337080832
    m_Localized: 'Cut deep, cut deeper, rip your layers!

      Torment will be your
      life, and its end will be

      your death!'
    m_Metadata:
      m_Items: []
  - m_Id: 7994187966636032
    m_Localized: '...and you will never feel its embrace.

      Self harm cannot
      kill you.'
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []

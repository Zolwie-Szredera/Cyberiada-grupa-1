  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogues_pl
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: pl
  m_SharedData: {fileID: 11400000, guid: f0996fd03d3820b41b70c5cae92a57ef, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 9391366144
    m_Localized: "Lilia pe\u0142na \u017Calu czeka na zerwanie,"
    m_Metadata:
      m_Items: []
  - m_Id: 64684875776
    m_Localized: "Po\u0142\xF3\u017C j\u0105 na grobie swojej ukochanej..."
    m_Metadata:
      m_Items: []
  - m_Id: 2430775648256
    m_Localized: "Cho\u0107 nikogo takiego nie pami\u0119tasz, \nto fragmenty pami\u0119ci
      z innego \u015Bwiata \nprzepe\u0142niaj\u0105 ci\u0119 ch\u0119ci\u0105 do
      ucieczki."
    m_Metadata:
      m_Items: []
  - m_Id: 692238749589504
    m_Localized: "Wi\u0119c uciekaj! Zdobyto Lili\u0119 Cieni,\nsi\u0142a dasha zosta\u0142a
      zwi\u0119kszona"
    m_Metadata:
      m_Items: []
  - m_Id: 7180529523023872
    m_Localized: "Co\u015B pi\u0119knego...\nJakie cuda skrywaj\u0105 si\u0119 w
      komnatach tego\npa\u0142acu?"
    m_Metadata:
      m_Items: []
  - m_Id: 7988329568329728
    m_Localized: "I jaki b\xF3l b\u0119dziesz musia\u0142 wytrzyma\u0107,\nby je
      zobaczy\u0107?\nWrogowie nadchodz\u0105..."
    m_Metadata:
      m_Items: []
  - m_Id: 7989706600275968
    m_Localized: 'Na plakietce pisze:

      "Najlepszy jest jedynym"'
    m_Metadata:
      m_Items: []
  - m_Id: 7990605292822528
    m_Localized: "Obdarty kawa\u0142 sk\xF3ry pokazany jak trofeum."
    m_Metadata:
      m_Items: []
  - m_Id: 7991275337080832
    m_Localized: "Tnij g\u0142\u0119boko, tnij g\u0142\u0119biej! Rozerwij warstwy!\nCierpienie
      to twoje \u017Cycie, a jego koniec jest\nko\u0144cem ciebie."
    m_Metadata:
      m_Items: []
  - m_Id: 7994187966636032
    m_Localized: "...kt\xF3rego nigdy nie do\u015Bwiadczysz.\nNie mo\u017Cesz si\u0119
      zabi\u0107 samookaleczeniem\nz zakl\u0119cia kewi."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
